# ============================================================
# Middleware Service — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# URL of the Subscription Service
SUBSCRIPTION_SERVICE_URL=http://localhost:8000

# URL of the Pharmacy Service
PHARMACY_URL=http://localhost:3001

# Timeout in seconds for downstream HTTP calls
SUBSCRIPTION_TIMEOUT_SECONDS=10
PHARMACY_TIMEOUT_SECONDS=10

# Business rules
# Discount percentage applied to PREMIUM plan orders (e.g. 10 = 10%)
PREMIUM_DISCOUNT_PERCENT=10
