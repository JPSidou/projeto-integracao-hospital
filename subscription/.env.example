# ============================================================
# Subscription Service — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# SQLite database path (relative to the subscription/ directory)
DATABASE_URL=sqlite:///./subscription.db

# JWT configuration
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Plan pricing (used for reference; actual values are seeded into the DB)
BASIC_PLAN_PRICE=29.90
PREMIUM_PLAN_PRICE=79.90
